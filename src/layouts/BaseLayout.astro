---
import '../styles/global.css';
import { withBase } from '../lib/url';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title} — Vacay</title>

    <link rel="icon" href={withBase('/icons/icon.svg')} type="image/svg+xml" />
    <link rel="icon" href={withBase('/favicon-32.png')} sizes="32x32" type="image/png" />
    <link rel="icon" href={withBase('/favicon-16.png')} sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href={withBase('/icons/apple-touch-icon.png')} />
    <link rel="manifest" href={withBase('/manifest.json')} />
    <meta name="theme-color" content="#0F4C4A" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Vacay" />
  </head>
  <body>
    <slot />
  </body>
</html>
